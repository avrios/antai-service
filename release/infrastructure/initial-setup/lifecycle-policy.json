{
  "rules": [
    {
      "rulePriority": 1,
      "description": "Expire release candidate images older than 10 days",
      "selection": {
        "tagPrefixList": [
          "RC-"
        ],
        "countType": "sinceImagePushed",
        "countUnit": "days",
        "countNumber": 10,
        "tagStatus": "tagged"
      },
      "action": {
        "type": "expire"
      }
    },
    {
      "rulePriority": 2,
      "description": "Keep only the 10 latest production images",
      "selection": {
        "tagPrefixList": [
          "RELEASE-"
        ],
        "countType": "imageCountMoreThan",
        "countNumber": 10,
        "tagStatus": "tagged"
      },
      "action": {
        "type": "expire"
      }
    }
  ]
}
