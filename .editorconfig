root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 140
tab_width = 4
ij_continuation_indent_size = 4
ij_formatter_off_tag = @formatter:off
ij_formatter_on_tag = @formatter:on
ij_formatter_tags_enabled = false
ij_visual_guides = 140
ij_wrap_on_typing = false

[*.{js,ts}]
# https://youtrack.jetbrains.com/issue/IDEA-262560/IntelliJ-doesnt-respect-quotetype-in-.editorconfig
ij_javascript_use_double_quotes = false
ij_typescript_use_double_quotes = false

[*.{json,scss,yaml}]
tab_width = 2
indent_size = 2

[{.prettierrc,.eslintrc}]
tab_width = 2
indent_size = 2
